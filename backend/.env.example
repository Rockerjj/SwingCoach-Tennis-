# Tennique backend env template. Copy to backend/.env and fill in values.
# Never commit the real .env file (it's gitignored).

# Set DEBUG=true ONLY in local development. In production it loosens auth
# and turns on verbose logging. ALWAYS DEBUG=false in Railway/production.
DEBUG=false

# Coaching provider selection. Eval-v1 picked Claude Opus 4.7 as the winner
# (see EVAL-V1-RESULTS.md). Valid values:
#   claude_opus    - Claude Opus 4.7 (production default, best quality, ~$0.69/session)
#   claude_sonnet  - Claude Sonnet 4.6 (~$0.18/session, slower, future cost-optimization)
#   gemini         - Gemini 2.5 Pro (~$0.08/session, but bare-stroke-list issues)
#   openai         - GPT (fallback only, requires OPENAI_API_KEY)
#   auto           - Legacy Gemini-then-OpenAI fallback for back-compat
COACHING_PROVIDER=claude_opus

# --- Anthropic (production primary) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_OPUS_MODEL=claude-opus-4-7
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6

# --- Gemini (alternate / cheap fallback) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro
USE_GEMINI=true

# --- OpenAI (last-resort fallback) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Apple Auth ---
APPLE_TEAM_ID=your-team-id
APPLE_BUNDLE_ID=com.tennisiq.app

# --- Eval / dev-only flags ---
# DO NOT enable in production. When true, /sessions/analyze writes incoming
# multipart payloads to PAYLOAD_CAPTURE_DIR for the eval harness.
DEBUG_CAPTURE_PAYLOADS=false
PAYLOAD_CAPTURE_DIR=test-data/sessions
